            "relevance": {
              "type": "object",
              "preliminary_value": "string",
              "review_status": "string",
              "basis": "string"
            },
            "probative_value": {
              "type": "object",
              "preliminary_value": "string",
              "review_status": "string",
              "basis": "string"
            },
            "weight": {
              "type": "object",
              "weight_level": "string",
              "suggested_score": "number|null",
              "review_status": "string",
              "basis": "string"
            }
          }
        },
        "burden_result": {
          "type": "object",
          "description": "举证责任结果",
          "properties": {
            "party_sufficient": "object",
            "facts_undetermined": "array",
            "burden_applied_summary": "string"
          }
        }
      },
      "handoff_to_next": {
        "condition": "事实认定完成，真伪不明情况已处理",
        "output_to_pass": ["fact_findings", "evidence_evaluation", "burden_result"],
        "next_step": "S9"
      },
      "blocking_conditions": [
