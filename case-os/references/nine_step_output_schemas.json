      "handoff_to_next": {
        "condition": "举证责任分配完成，心证公开完成",
        "output_to_pass": ["burden_allocation", "proof_resource_review.resources_exhausted"],
        "next_step": "S8"
      },
      "blocking_conditions": [
        "举证责任分配错误且无法纠正",
        "心证公开不足导致举证不充分",
        "证明资源未用尽且无法补充"
      ]
    },
    "S8": {
      "step_id": "S8",
      "step_name": "事实认定",
      "input_schema": {
        "burden_allocation": {
          "type": "array",
          "description": "S7输出的举证责任分配",
